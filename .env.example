# Server
PORT=8090
# In production we run with docker `network_mode: host` and listen on
# 127.0.0.1 only — cloudflared on the same host is the only public path.
HOST=127.0.0.1
NODE_ENV=production

# MariaDB connection. With network_mode: host we can reach MariaDB at
# 127.0.0.1:3306 directly (it's bound to loopback on the host).
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=eah
DB_PASSWORD=changeme
DB_NAME=eah

# Random 32+ byte secret used for signing session cookies and hashing IPs.
# Generate with: openssl rand -hex 32
SESSION_SECRET=changeme_to_a_long_random_hex_string

# Set once, on first deploy, to create the bootstrap admin via `bun scripts/seed-admin.ts`.
# seed-admin is now an upsert: re-running it with new values updates the
# email / password of the named admin (useful after the admins -> users
# migration, which left existing admins with a placeholder email).
# Unset after the admin is fully set up.
ADMIN_BOOTSTRAP_USER=
ADMIN_BOOTSTRAP_EMAIL=
ADMIN_BOOTSTRAP_PASS=

# Monthly outbound email cap. The free Resend tier is 300/month; we default
# to 280 to leave headroom for transactional review-decision mail after we
# hide the email-signup option. Set to 0 to disable the gate.
EMAIL_MONTHLY_CAP=280

# Google Identity Services (GIS) client id. Get it at
# https://console.cloud.google.com → APIs & Services → Credentials (OAuth 2.0
# Client ID). The embedded GIS button returns an ID token to the browser which
# we verify locally against Google's JWKS — there is NO server-side code
# exchange, so no client secret and no redirect/callback URI are needed. You
# only need to configure "Authorized JavaScript origins" (your site origin) in
# the Cloud Console, not "Authorized redirect URIs".
# Leave blank to hide the "Continue with Google" buttons.
GOOGLE_CLIENT_ID=

# If "true", show the "IN DEVELOPMENT, MAY CHANGE" banner. Set "false" once stable.
IN_DEVELOPMENT=true

# Optional. Resend API key for outbound submitter notifications and the
# /lookup digest mail. If unset, those features no-op cleanly (the site
# keeps working without email). Provide either RESEND_API_KEY directly or
# RESEND_API_KEY_FILE pointing to a file containing just the key.
RESEND_API_KEY=
# RESEND_API_KEY_FILE=/home/interrobang/Credentials/resend_api_key.txt

# From address for outbound emails. The domain must be verified in Resend.
EMAIL_FROM=EAH <noreply@eah.warrenwoolf.com>
EMAIL_REPLY_TO=noreply@eah.warrenwoolf.com

# Public-facing address shown on /privacy for data-deletion / privacy requests.
PRIVACY_EMAIL=privacy@eah.warrenwoolf.com

# Used to build absolute URLs inside outbound emails.
PUBLIC_BASE_URL=https://eah.warrenwoolf.com

# NOTE: Cloudflare cache-purge creds are NOT app config and do NOT live here.
# deploy.sh reads them from local files on the deploying machine
# (~/Credentials/cloudflare-account-id.txt and
# ~/Credentials/cloudflare-ww-purge-token.txt) to purge /static/* after deploy.
# Override the paths with CF_ACCOUNT_ID_FILE / CF_TOKEN_FILE if needed.
