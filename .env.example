# Server
PORT=8090
NODE_ENV=production

# MariaDB connection
DB_HOST=172.17.0.1
DB_PORT=3306
DB_USER=eah
DB_PASSWORD=changeme
DB_NAME=eah

# Random 32+ byte secret used for signing session cookies and hashing IPs.
# Generate with: openssl rand -hex 32
SESSION_SECRET=changeme_to_a_long_random_hex_string

# Set once, on first deploy, to create the bootstrap admin via `bun scripts/seed-admin.ts`.
# Unset after the admin is created.
ADMIN_BOOTSTRAP_USER=
ADMIN_BOOTSTRAP_PASS=

# If "true", show the "IN DEVELOPMENT, MAY CHANGE" banner. Set "false" once stable.
IN_DEVELOPMENT=true
